{
  "expo": {
    "name": "OpenDev",
    "slug": "opendev",
    "scheme": "opendev",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#05070b" },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.opendev.app",
      "infoPlist": {
        "CFBundleDisplayName": "OpenDev",
        "NSCameraUsageDescription": "OpenDev uses the camera to capture project screenshots, app previews, and visual assets.",
        "NSPhotoLibraryUsageDescription": "OpenDev uses your library to attach images, videos, screenshots, and design assets to projects."
      }
    },
    "android": {
      "package": "com.opendev.app",
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES", "READ_MEDIA_VIDEO", "POST_NOTIFICATIONS"]
    },
    "plugins": ["expo-camera", "expo-image-picker", "expo-notifications"]
  }
}
