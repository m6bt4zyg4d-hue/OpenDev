{
  "expo": {
    "name": "Media",
    "slug": "media",
    "scheme": "media",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#05070b" },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.media.app", "infoPlist": { "NSCameraUsageDescription": "Media uses the camera to capture posts, stories, and live stream previews.", "NSPhotoLibraryUsageDescription": "Media uses your library to attach photos and videos to posts and stories." } },
    "android": { "package": "com.media.app", "permissions": ["CAMERA", "READ_MEDIA_IMAGES", "READ_MEDIA_VIDEO", "POST_NOTIFICATIONS"] },
    "plugins": ["expo-camera", "expo-image-picker", "expo-notifications"]
  }
}
