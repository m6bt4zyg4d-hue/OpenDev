{
  "name": "@opendev/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:ios": "eas build --platform ios --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:simulator": "eas build --platform ios --profile ios-simulator",
    "submit:ios": "eas submit --platform ios --profile production",
    "check:apple-connect": "node ../../scripts/check-apple-connect.mjs",
    "connect:apple": "eas submit:configure --platform ios",
    "build:ios:testflight": "eas build --platform ios --profile production --auto-submit"
  },
  "dependencies": {
    "@opendev/api": "0.1.0",
    "@opendev/design-system": "0.1.0",
    "@opendev/types": "0.1.0",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@supabase/supabase-js": "^2.45.4",
    "expo": "^51.0.20",
    "expo-camera": "^15.0.14",
    "expo-image-picker": "^15.0.7",
    "expo-notifications": "^0.28.13",
    "expo-status-bar": "^1.12.1",
    "react": "^18.3.1",
    "react-native": "^0.74.3",
    "react-native-safe-area-context": "^4.10.8",
    "react-native-screens": "^3.32.0",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4"
  }
}
