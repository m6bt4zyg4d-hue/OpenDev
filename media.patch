index 0000000000000000000000000000000000000000..3ee0fc36d019eb5ccb1fb46e7059682b106f5bbe
--- /dev/null
+++ b/apps/web/components/EditProfileForm.tsx
@@ -0,0 +1,35 @@
+'use client';
+
+import { FormEvent, useEffect, useState } from 'react';
+import { mediaRepository } from '../lib/supabase';
+import { useAuth } from './AuthProvider';
+
+export function EditProfileForm() {
+  const { profile, refreshProfile } = useAuth();
+  const [displayName, setDisplayName] = useState('');
+  const [username, setUsername] = useState('');
+  const [bio, setBio] = useState('');
+  const [avatarUrl, setAvatarUrl] = useState('');
+  const [bannerUrl, setBannerUrl] = useState('');
+  const [message, setMessage] = useState('');
+
+  useEffect(() => {
+    setDisplayName(profile?.displayName ?? '');
+    setUsername(profile?.username ?? '');
+    setBio(profile?.bio ?? '');
+    setAvatarUrl(profile?.avatarUrl ?? '');
+    setBannerUrl(profile?.bannerUrl ?? '');
+  }, [profile]);
+
+  async function submit(event: FormEvent) {
+    event.preventDefault();
+    const { error } = await mediaRepository.updateProfile({ displayName, username, bio, avatarUrl, bannerUrl });
+    if (error) setMessage(error.message);
+    else {
+      await refreshProfile();
+      setMessage('Profile updated.');
+    }
+  }
+
