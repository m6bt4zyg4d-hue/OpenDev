{
  "name": "media-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Media social platform monorepo for mobile, web, shared packages, and Supabase backend.",
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
